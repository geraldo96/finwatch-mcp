# finwatch-mcp environment configuration
# Copy this file to .env and fill in your API keys

# === Required ===
ANTHROPIC_API_KEY=sk-ant-your-key-here

# === Data Sources (free tiers) ===
ALPHA_VANTAGE_API_KEY=your-key-here        # https://www.alphavantage.co/support/#api-key
FINNHUB_API_KEY=your-key-here              # https://finnhub.io/register

# === Optional ===
# FRED doesn't require an API key for basic access
# SEC EDGAR requires a User-Agent header (set below)
SEC_EDGAR_USER_AGENT=finwatch-mcp geraldo.margjini@example.com

# === Server Config ===
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8080
DATABASE_URL=sqlite:///data/finwatch.db
CHROMA_PERSIST_DIR=data/chroma

# === Agent Config ===
CLAUDE_MODEL=claude-sonnet-4-20250514
MAX_AGENT_STEPS=10
